# Generated by openclaw-deploy ansible
apiVersion: 1

datasources:
  - name: Prometheus
    uid: prometheus
    type: prometheus
    access: proxy
    url: http://{{ telemetry.host }}:{{ telemetry.prometheus.port }}
    isDefault: true
    editable: true

  - name: Phoenix
    uid: phoenix
    type: prometheus
    access: proxy
    url: http://{{ telemetry.host }}:{{ telemetry.phoenix.prometheus_port }}
    editable: true

{% if telemetry.loki is defined %}
  - name: Loki
    uid: loki
    type: loki
    access: proxy
    url: http://{{ telemetry.host }}:{{ telemetry.loki.port }}
    editable: true
    jsonData:
      derivedFields:
        - datasourceUid: prometheus
          matcherRegex: "provider=(\\w+)"
          name: Provider
          url: ""
{% endif %}
