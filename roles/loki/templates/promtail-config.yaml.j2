# Generated by openclaw-deploy ansible
server:
  http_listen_address: {{ telemetry.host }}
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://{{ telemetry.host }}:{{ telemetry.loki.port }}/loki/api/v1/push

scrape_configs:
  - job_name: journal
    journal:
      json: false
      max_age: 12h
      labels:
        host: {{ ansible_hostname }}
    relabel_configs:
      # Only keep logs from services we care about
      - source_labels: ['__journal__systemd_unit']
        regex: '(openclaw|llamafirewall|pipelock|locksmith|caddy|docker|prometheus|grafana|otel-collector|phoenix|loki|promtail|nftables)\.service'
        action: keep
      - source_labels: ['__journal__systemd_unit']
        target_label: unit
      - source_labels: ['__journal_priority_keyword']
        target_label: level
