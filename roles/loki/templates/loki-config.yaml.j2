# Generated by openclaw-deploy ansible
auth_enabled: false

server:
  http_listen_address: {{ telemetry.host }}
  http_listen_port: {{ telemetry.loki.port }}

common:
  path_prefix: {{ telemetry.loki.data_dir }}
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: "2024-01-01"
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

storage_config:
  filesystem:
    directory: {{ telemetry.loki.data_dir }}/chunks
  tsdb_shipper:
    active_index_directory: {{ telemetry.loki.data_dir }}/tsdb-index
    cache_location: {{ telemetry.loki.data_dir }}/tsdb-cache

limits_config:
  retention_period: {{ telemetry.loki.retention }}
  reject_old_samples: true
  reject_old_samples_max_age: 168h

compactor:
  working_directory: {{ telemetry.loki.data_dir }}/compactor
  retention_enabled: true
  delete_request_store: filesystem
