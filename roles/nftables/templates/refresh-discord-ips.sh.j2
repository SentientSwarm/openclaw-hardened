#!/bin/bash
set -euo pipefail
# Resolve Discord domains and populate nftables discord_ips set.
# Run by refresh-discord-ips.timer every 5 minutes.

IPS=$(dig +short gateway.discord.gg discord.com cdn.discordapp.com 2>/dev/null \
    | sort -u | grep -E '^[0-9]') || true

if [ -z "$IPS" ]; then
    logger -t refresh-discord-ips "DNS resolution failed, skipping"
    exit 0
fi

nft flush set inet openclaw discord_ips
ELEMENTS=$(echo "$IPS" | paste -sd, -)
nft add element inet openclaw discord_ips "{ $ELEMENTS }"
logger -t refresh-discord-ips "Updated $(echo "$IPS" | wc -l) IPs"
